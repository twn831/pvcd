# Cloudflare R2 Storage Configuration
R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_DOMAIN=your_bucket.public_url

# Authentication Configuration
PASSWORD_1=your_secure_password_1
PASSWORD_2=your_secure_password_2
PASSWORD_3=your_secure_password_3

# Storage Limit (default: 10GB = 10737418240 bytes)
STORAGE_LIMIT=10737418240

# Node.js Version (for Cloudflare Pages compatibility)
NODE_VERSION=20
